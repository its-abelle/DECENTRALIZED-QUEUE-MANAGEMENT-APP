<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<!-- 
  DQMS — Decentralized Queue Management System
  Chuka University Project
  UI Layout for Admin and Student Roles
-->

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.dqms.ui.MainController"
           prefWidth="1000" prefHeight="680"
           style="-fx-background-color: white;">

    <!-- Login Screen -->
    <VBox fx:id="loginScreen" alignment="CENTER">
        
        <!-- Header Bar -->
        <HBox prefHeight="60" alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #13C9F0; -fx-padding: 0 30 0 30;">
            <ImageView fx:id="headerLogoLogin" fitWidth="40" fitHeight="40" preserveRatio="true"/>
            <VBox alignment="CENTER_LEFT">
                <Label text="CHUKA UNIVERSITY"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Decentralized Queue Management System"
                       style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.9);"/>
            </VBox>
        </HBox>

        <!-- Main Login Area -->
        <VBox alignment="CENTER" VBox.vgrow="ALWAYS" style="-fx-background-color: #f0fbfe;">
            <VBox maxWidth="420" alignment="CENTER" spacing="0"
                  style="-fx-background-color: white; -fx-border-color: #b8edf7; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(19,201,240,0.1), 30, 0, 0, 5);">

                <!-- University Branding -->
                <StackPane>
                    <Circle radius="45" fill="#e4f9fd" stroke="#13C9F0" strokeWidth="2"/>
                    <ImageView fitWidth="65" fitHeight="65" preserveRatio="true"/>
                </StackPane>
                
                <Label text="CHUKA UNIVERSITY" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0a2d38;">
                    <VBox.margin><Insets top="15" bottom="5"/></VBox.margin>
                </Label>
                <Label text="Queue Management System" style="-fx-font-size: 12px; -fx-text-fill: #13C9F0; -fx-font-weight: bold;">
                    <VBox.margin><Insets bottom="30"/></VBox.margin>
                </Label>

                <!-- Role Selection -->
                <Label text="SELECT YOUR ROLE" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0; -fx-letter-spacing: 1px;">
                    <VBox.margin><Insets bottom="10"/></VBox.margin>
                </Label>

                <HBox spacing="15" alignment="CENTER">
                    <VBox.margin><Insets bottom="25"/></VBox.margin>
                    
                    <VBox fx:id="roleStudent" alignment="CENTER" spacing="8" prefWidth="120" prefHeight="85"
                          style="-fx-background-color: #e4f9fd; -fx-border-color: #13C9F0; -fx-border-width: 2; -fx-border-radius: 12; -fx-background-radius: 12; -fx-cursor: hand;"
                          onMouseClicked="#onSelectStudent">
                        <StackPane>
                            <Circle radius="10" fill="#13C9F0" translateY="-5"/>
                            <Ellipse radiusX="14" radiusY="9" fill="#13C9F0" translateY="10"/>
                        </StackPane>
                        <Label text="Student" style="-fx-font-weight: bold; -fx-text-fill: #0a2d38; -fx-font-size: 12px;"/>
                    </VBox>

                    <VBox fx:id="roleAdmin" alignment="CENTER" spacing="8" prefWidth="120" prefHeight="85"
                          style="-fx-background-color: white; -fx-border-color: #c8eef7; -fx-border-width: 2; -fx-border-radius: 12; -fx-background-radius: 12; -fx-cursor: hand;"
                          onMouseClicked="#onSelectAdmin">
                        <StackPane>
                            <Circle radius="10" fill="#13C9F0" translateY="-5"/>
                            <Ellipse radiusX="14" radiusY="9" fill="#13C9F0" translateY="10"/>
                        </StackPane>
                        <Label text="System Admin" style="-fx-font-weight: bold; -fx-text-fill: #0a2d38; -fx-font-size: 12px;"/>
                    </VBox>
                </HBox>

                <!-- Dynamic Input Fields -->
                <VBox fx:id="studentFields" spacing="5">
                    <Label text="REGISTRATION NUMBER" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                    <TextField fx:id="loginRegField" promptText="e.g. SCT221-0001/2022"
                               style="-fx-background-color: white; -fx-border-color: #b8edf7; -fx-border-radius: 8; -fx-padding: 10;"/>
                </VBox>

                <VBox fx:id="staffFields" spacing="5" visible="false" managed="false">
                    <Label text="STAFF / NODE ID" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                    <TextField fx:id="loginStaffId" promptText="e.g. ADMIN_01"
                               style="-fx-background-color: white; -fx-border-color: #b8edf7; -fx-border-radius: 8; -fx-padding: 10;"/>
                    <Label text="PASSWORD" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;">
                        <VBox.margin><Insets top="10"/></VBox.margin>
                    </Label>
                    <PasswordField fx:id="loginPassword"
                                   style="-fx-background-color: white; -fx-border-color: #b8edf7; -fx-border-radius: 8; -fx-padding: 10;"/>
                </VBox>

                <VBox fx:id="portField" spacing="5" visible="false" managed="false">
                    <Label text="NETWORK PORT" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;">
                        <VBox.margin><Insets top="10"/></VBox.margin>
                    </Label>
                    <TextField fx:id="loginPort" promptText="5001"
                               style="-fx-background-color: white; -fx-border-color: #b8edf7; -fx-border-radius: 8; -fx-padding: 10;"/>
                </VBox>

                <Button fx:id="loginButton" text="Access System" onAction="#onLogin"
                        prefWidth="Infinity" prefHeight="45"
                        style="-fx-background-color: #13C9F0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;">
                    <VBox.margin><Insets top="30" bottom="10"/></VBox.margin>
                </Button>

                <Label fx:id="loginError" style="-fx-text-fill: #dc2626; -fx-font-size: 12px;"/>
            </VBox>
        </VBox>

        <!-- Footer -->
        <HBox prefHeight="35" alignment="CENTER" style="-fx-background-color: #13C9F0;">
            <Label text="© 2026 Chuka University · Decentralized Queue System" style="-fx-font-size: 10px; -fx-text-fill: white;"/>
        </HBox>
    </VBox>

    <!-- Student Interface -->
    <VBox fx:id="studentScreen" visible="false" managed="false" style="-fx-background-color: white;">
        <HBox prefHeight="60" alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #13C9F0; -fx-padding: 0 25 0 25;">
            <ImageView fitWidth="35" fitHeight="35" preserveRatio="true"/>
            <VBox HBox.hgrow="ALWAYS">
                <Label text="STUDENT PORTAL" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 15px;"/>
                <Label text="Chuka University — Finance Queue" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.85);"/>
            </VBox>
            <HBox alignment="CENTER" spacing="10" style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 15 5 15; -fx-background-radius: 20;">
                <Label fx:id="studentNamePill" text="Student" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px;"/>
            </HBox>
            <Button text="Log Out" onAction="#onLogout" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;"/>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: #e8fbfe;">
            <VBox maxWidth="450" alignment="CENTER" spacing="25"
                  style="-fx-background-color: white; -fx-border-color: #b8edf7; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 20, 0, 0, 5);">
                
                <Label text="Queue Registration" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0a2d38;"/>
                
                <VBox spacing="10" alignment="CENTER_LEFT">
                    <VBox spacing="5">
                        <Label text="REGISTRATION NUMBER" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                        <TextField fx:id="studentRegField" promptText="e.g. SCT221-0001/2022" style="-fx-background-color: #f8fdff; -fx-border-color: #b8edf7; -fx-border-radius: 8; -fx-padding: 12;"/>
                    </VBox>
                    <VBox spacing="5">
                        <Label text="FULL NAME" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                        <TextField fx:id="studentNameField" promptText="Your official name" style="-fx-background-color: #f8fdff; -fx-border-color: #b8edf7; -fx-border-radius: 8; -fx-padding: 12;"/>
                    </VBox>
                </VBox>

                <Button fx:id="getTicketBtn" text="Request Queue Position" onAction="#onGetTicket"
                        prefWidth="Infinity" prefHeight="48"
                        style="-fx-background-color: #13C9F0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                
                <Label fx:id="studentError" style="-fx-text-fill: #dc2626;"/>

                <VBox fx:id="ticketBox" visible="false" managed="false" spacing="20"
                      style="-fx-background-color: #e4f9fd; -fx-border-color: #13C9F0; -fx-border-width: 2; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 25;">
                    
                    <VBox alignment="CENTER">
                        <Label text="YOUR POSITION" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                        <Label fx:id="ticketPosition" text="#—" style="-fx-font-size: 55px; -fx-font-weight: bold; -fx-text-fill: #13C9F0;"/>
                    </VBox>

                    <Separator style="-fx-opacity: 0.3;"/>

                    <HBox alignment="CENTER" spacing="30">
                        <VBox alignment="CENTER">
                            <Label text="STATUS" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                            <Label fx:id="ticketStatus" text="WAITING" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #d97706;"/>
                        </VBox>
                        <VBox alignment="CENTER">
                            <Label text="ISSUED" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                            <Label fx:id="ticketTimeLabel" text="00:00" style="-fx-font-size: 12px; -fx-text-fill: #0a2d38;"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="8" alignment="CENTER">
                        <ProgressBar fx:id="queueProgress" prefWidth="Infinity" prefHeight="10" progress="0.0"/>
                        <Label fx:id="aheadLabel" text="Tracking position..." style="-fx-font-size: 11px; -fx-text-fill: #5a8fa0;"/>
                    </VBox>
                </VBox>
            </VBox>
        </StackPane>
    </VBox>

    <!-- Admin Dashboard -->
    <VBox fx:id="adminScreen" visible="false" managed="false" style="-fx-background-color: white;">
        <HBox prefHeight="65" alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #13C9F0; -fx-padding: 0 30 0 30;">
            <ImageView fitWidth="40" fitHeight="40" preserveRatio="true"/>
            <VBox HBox.hgrow="ALWAYS">
                <Label text="ADMINISTRATOR PANEL" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 16px;"/>
                <Label fx:id="adminSubLabel" text="System Monitoring" style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.85);"/>
            </VBox>
            <Button text="View Dashboard" onAction="#onShowDashboard" 
                    style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 15;"/>
            <Button text="Sign Out" onAction="#onLogout" 
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 8; -fx-cursor: hand; -fx-padding: 8 15;"/>
        </HBox>

        <HBox VBox.vgrow="ALWAYS" style="-fx-background-color: #e8fbfe; -fx-padding: 20;">
            
            <!-- Side Navigation -->
            <VBox prefWidth="80" alignment="TOP_CENTER" spacing="10" 
                  style="-fx-background-color: #13C9F0; -fx-background-radius: 15; -fx-padding: 20 0;">
                <Button fx:id="navQueue" text="Queue" onAction="#onNavQueue" prefWidth="60" prefHeight="60" 
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-background-radius: 12;"/>
                <Button fx:id="navPeers" text="Peers" onAction="#onNavPeers" prefWidth="60" prefHeight="60" 
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 10px; -fx-background-radius: 12;"/>
                <Button fx:id="navLog" text="Logs" onAction="#onNavLog" prefWidth="60" prefHeight="60" 
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 10px; -fx-background-radius: 12;"/>
            </VBox>

            <!-- Main Workspace -->
            <VBox HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 0 0 0 20;">
                
                <!-- Metrics Summary -->
                <HBox spacing="15">
                    <VBox alignment="CENTER" spacing="5" prefWidth="180" prefHeight="90" 
                          style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #b8edf7; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 10, 0, 0, 2);">
                        <Label text="WAITING" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                        <Label fx:id="waitingCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #d97706;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" prefWidth="180" prefHeight="90" 
                          style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #b8edf7; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 10, 0, 0, 2);">
                        <Label text="SERVED" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                        <Label fx:id="clearedCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" prefWidth="180" prefHeight="90" 
                          style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #b8edf7; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.03), 10, 0, 0, 2);">
                        <Label text="ACTIVE PEERS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                        <Label fx:id="peerCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #13C9F0;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Reset Global Queue" onAction="#onResetQueue" 
                            style="-fx-background-color: white; -fx-text-fill: #dc2626; -fx-border-color: #dc2626; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 15; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 11px;">
                        <HBox.margin><Insets right="10"/></HBox.margin>
                    </Button>
                    <VBox alignment="CENTER_RIGHT">
                        <Label fx:id="nodeLabel" visible="false" managed="false"/>
                        <Label fx:id="statusLabel" text="● Network Status" style="-fx-text-fill: #13C9F0; -fx-font-weight: bold; -fx-background-color: #e4f9fd; -fx-padding: 10 20; -fx-background-radius: 20;"/>
                    </VBox>
                </HBox>

                <!-- Tabbed Content -->
                <StackPane VBox.vgrow="ALWAYS">
                    <!-- Queue Table Tab -->
                    <HBox fx:id="tabQueue" spacing="15">
                        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #b8edf7; -fx-overflow: hidden;">
                            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 15; -fx-background-color: #e4f9fd;">
                                <Label text="Live Queue View" style="-fx-font-weight: bold; -fx-text-fill: #0a2d38;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Reload Data" onAction="#onRefresh" style="-fx-background-color: white; -fx-border-color: #b8edf7; -fx-border-radius: 5; -fx-cursor: hand;"/>
                                <Button fx:id="clearBtn" text="Mark as Cleared" onAction="#onClearSelected" disable="true"
                                        style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
                            </HBox>
                            <TableView fx:id="queueTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                <columns>
                                    <TableColumn fx:id="posCol" text="#" prefWidth="50"/>
                                    <TableColumn fx:id="regCol" text="Reg Number" prefWidth="180"/>
                                    <TableColumn fx:id="nameCol" text="Name" prefWidth="200"/>
                                    <TableColumn fx:id="nodeCol" text="Origin Node" prefWidth="120"/>
                                    <TableColumn fx:id="timeCol" text="Time" prefWidth="100"/>
                                    <TableColumn fx:id="statusCol" text="Status" prefWidth="120"/>
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            </TableView>
                        </VBox>

                        <!-- Add Student Panel -->
                        <VBox prefWidth="280" spacing="0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #b8edf7; -fx-max-height: 300;">
                            <Label text="Manual Add" style="-fx-background-color: #e4f9fd; -fx-padding: 15; -fx-font-weight: bold; -fx-text-fill: #0a2d38; -fx-pref-width: 300;"/>
                            <VBox spacing="15" style="-fx-padding: 20;">
                                <VBox spacing="5">
                                    <Label text="REGISTRATION NO" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                                    <TextField fx:id="regNumberField" style="-fx-background-color: #f8fdff; -fx-border-color: #b8edf7; -fx-border-radius: 5;"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="STUDENT NAME" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                                    <TextField fx:id="studentNameFieldAdmin" style="-fx-background-color: #f8fdff; -fx-border-color: #b8edf7; -fx-border-radius: 5;"/>
                                </VBox>
                                <Button fx:id="joinButton" text="Add to Queue" onAction="#onJoinQueue" prefWidth="Infinity" 
                                        style="-fx-background-color: #13C9F0; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10;"/>
                                <Label fx:id="joinFeedback" style="-fx-font-size: 11px;"/>
                            </VBox>
                        </VBox>
                    </HBox>

                    <!-- Peers Tab -->
                    <VBox fx:id="tabPeers" visible="false" managed="false" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #b8edf7; -fx-padding: 20;">
                        <Label text="Network Peer Discovery" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0a2d38;"/>
                        <Separator style="-fx-padding: 10 0;"/>
                        <VBox fx:id="peerListContainer" spacing="10"/>
                    </VBox>

                    <!-- Logs Tab -->
                    <VBox fx:id="tabLog" visible="false" managed="false" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #b8edf7;">
                        <Label text="System Operations Log" style="-fx-background-color: #e4f9fd; -fx-padding: 15; -fx-font-weight: bold; -fx-text-fill: #0a2d38; -fx-pref-width: 1000;"/>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                            <Label fx:id="syncLog" style="-fx-padding: 20; -fx-font-family: monospace;"/>
                        </ScrollPane>
                    </VBox>
                </StackPane>
            </VBox>
        </HBox>

        <!-- Status Bar -->
        <HBox prefHeight="35" alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #13C9F0; -fx-padding: 0 25;">
            <Label text="SYSTEM LOG:" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.7);"/>
            <Label fx:id="syncLogBar" text="Operational" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
        </HBox>
    </VBox>

    <!-- Admin Overview Popup -->
    <StackPane fx:id="dashboardPopup" visible="false" managed="false" style="-fx-background-color: rgba(0,0,0,0.4);">
        <VBox maxWidth="700" maxHeight="500" style="-fx-background-color: white; -fx-background-radius: 20; -fx-overflow: hidden; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 40, 0, 0, 10);">
            <HBox prefHeight="60" alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #13C9F0; -fx-padding: 0 25;">
                <Label text="Dashboard Summary" style="-fx-font-weight: bold; -fx-text-fill: white; -fx-font-size: 16px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="✕" onAction="#onCloseDashboard" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18px; -fx-cursor: hand;"/>
            </HBox>
            <VBox spacing="25" style="-fx-padding: 30;">
                <HBox spacing="20" alignment="CENTER">
                    <VBox alignment="CENTER" prefWidth="140" style="-fx-background-color: #e4f9fd; -fx-padding: 20; -fx-background-radius: 12;">
                        <Label text="WAITING" style="-fx-font-size: 9px; -fx-font-weight: bold;"/>
                        <Label fx:id="popupWaiting" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="140" style="-fx-background-color: #e4f9fd; -fx-padding: 20; -fx-background-radius: 12;">
                        <Label text="SERVED" style="-fx-font-size: 9px; -fx-font-weight: bold;"/>
                        <Label fx:id="popupCleared" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="140" style="-fx-background-color: #e4f9fd; -fx-padding: 20; -fx-background-radius: 12;">
                        <Label text="PEERS" style="-fx-font-size: 9px; -fx-font-weight: bold;"/>
                        <Label fx:id="popupPeers" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
                <VBox spacing="10">
                    <Label text="RECENT QUEUE ACTIVITY" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #5a8fa0;"/>
                    <ScrollPane prefHeight="150" style="-fx-background-color: #f8fdff; -fx-background-radius: 10; -fx-border-color: #b8edf7; -fx-border-radius: 10;">
                        <HBox fx:id="horizontalQueue" spacing="12" style="-fx-padding: 15;"/>
                    </ScrollPane>
                </VBox>
                <HBox style="-fx-background-color: #13C9F0; -fx-padding: 10 20; -fx-background-radius: 8;">
                    <Label text="LAST SYNC:" style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.7); -fx-padding: 0 10 0 0;"/>
                    <Label fx:id="popupSyncLog" text="System Ready" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>

